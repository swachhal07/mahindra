# ── Server ──
PORT=5174

# ── Vehicle / blog admin API (MongoDB Atlas) ──
# Connection string from Atlas → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/mahindra?retryWrites=true&w=majority

# Any long random string — signs the admin login tokens.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Admin login for the /login portal on the website.
# The account is created (or its password synced) automatically at startup.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=choose-a-strong-password
