# Copy this file to `.env.local` for local overrides, or set these as
# Environment Variables in your Vercel project.

# Origin of the deployed backend (Express + Nodemailer) — used by the booking
# form to POST submissions. Leave EMPTY for local dev: Vite proxies /api/*
# to localhost:5174 automatically (see vite.config.js).
#
# In production on Vercel, set this to your deployed backend URL, e.g.:
#   VITE_API_BASE_URL=https://mahindra-api.onrender.com
VITE_API_BASE_URL=
